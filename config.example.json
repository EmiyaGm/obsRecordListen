{
  "obs": {
    "host": "127.0.0.1",
    "port": 4455,
    "password": "your_obs_websocket_password",
    "timeout_seconds": 3
  },
  "bark": {
    "server": "https://api.day.app",
    "targets": [
      {
        "device_key": "your_device_key_1",
        "code": "your_code_1"
      },
      {
        "device_key": "your_device_key_2",
        "code": "your_code_2"
      }
    ],
    "group": "OBS Watchdog",
    "sound": "bell"
  },
  "monitor": {
    "check_interval_seconds": 5,
    "alert_cooldown_seconds": 60,
    "expect_recording": true,
    "expect_streaming": false,
    "detect_audio_silence": true,
    "audio_input_name": "Mic/Aux",
    "silence_threshold_db": -50,
    "silence_seconds": 90,
    "silence_only_when_output_active": true
  }
}
